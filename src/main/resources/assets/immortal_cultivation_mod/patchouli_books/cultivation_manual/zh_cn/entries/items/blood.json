  "pages": [
    {
      "type": "patchouli:text",
      "text": "\u4efb\u4f55\u975e\u73a9\u5bb6\u751f\u7269\u6b7b\u4ea1\u65f6\u90fd\u53ef\u6389\u843d\u8840\u6db2\uff0c\u5305\u62ec\u5176\u4ed6Mod\u7684\u751f\u7269\u3002\u6389\u843d\u6570\u91cf\u4e3a\u6700\u5927\u751f\u547d\u503c\u9664\u4ee510\u3002"
    },
    {
      "type": "patchouli:text",
      "text": "$(br)\u300a\u8840\u9b54\u529f\u300b\u4f1a\u89e3\u9501\u8840\u6c14\u6761\u3002\u53f3\u952e\u8840\u6db2\u53ef\u70bc\u53161\u70b9\u8840\u6c14\uff0c\u4e0a\u9650\u4e3a\u6700\u5927\u7075\u6c14\u768410\u500d\u3002$(br2)\u7075\u6c14\u4e0d\u8db3\u65f6\uff0c\u8840\u6c14\u53ef\u4ee5\u4ee3\u66ff\u7075\u6c14\u652f\u4ed8\u6cd5\u672f\u548c\u6548\u679c\u6d88\u8017\u3002"
    },
    {
      "type": "patchouli:text",
      "text": "$(br)\u300a\u8840\u9b54\u529f\u300b\u67093\u79cd\u7248\u672c\uff1a\u91d1\u4e39\u540e\u671f\u3001\u5143\u5a74\u540e\u671f\u3001\u5316\u795e\u540e\u671f\u3002$(br2)\u7a81\u7834\u65f6\u4fee\u4e3a\u8fdb\u5ea6\u4e0d\u8db3\u7684\u8bdd\uff0c\u4f1a\u81ea\u52a8\u6d88\u8017\u8840\u6c14\uff1a\u6bcf10\u70b9\u8840\u6c14\u589e\u52a01\u70b9\u4fee\u4e3a\u8fdb\u5ea6\u3002"
    }
  ]
