{
  "name": "\u529f\u6cd5",
  "icon": "immortal_cultivation_mod:basic_breathing_method",
  "category": "immortal_cultivation_mod:cultivation",
  "sortnum": 3,
  "pages": [
    {
      "type": "patchouli:text",
      "text": "\u73b0\u5728\u6253\u5750\u9700\u8981\u5148\u6fc0\u6d3b\u529f\u6cd5\u3002\u6ca1\u6709\u529f\u6cd5\u65f6\u4f9d\u7136\u53ef\u4ee5\u6253\u5750\uff0c\u4f46\u4fee\u4e3a\u8fdb\u5ea6\u4e0d\u4f1a\u589e\u52a0\u3002$(br2)\u53f3\u952e\u529f\u6cd5\u5377\u5373\u53ef\u6fc0\u6d3b\u3002"
    },
    {
      "type": "patchouli:text",
      "text": "$(br)\u6bcf\u95e8\u529f\u6cd5\u90fd\u6709\u4fee\u70bc\u4e0a\u9650\u3002\u300a\u57fa\u7840\u5410\u7eb3\u6cd5\u300b\u548c\u300a\u6e05\u5fc3\u8bc0\u300b\u5230\u7b51\u57fa\u540e\u671f\u540e\u4e0d\u518d\u589e\u52a0\u4fee\u4e3a\u3002$(br2)\u529f\u6cd5\u54c1\u9636\u4e3a\uff1a\u51e1\u9636\u3001\u9ec4\u9636\u3001\u7384\u9636\u3001\u5730\u9636\u3001\u5929\u9636\u3001\u4ed9\u9636\u3002"
    },
    {
      "type": "patchouli:text",
      "text": "$(br)\u5c5e\u6027\u529f\u6cd5\u4f1a\u4e0e\u7075\u6839\u5339\u914d\u3002\u5f3a\u5339\u914d\u53ef\u63d0\u9ad8\u4fee\u70bc\u901f\u5ea6\u3001\u5a01\u529b\u5e76\u964d\u4f4e\u6d88\u8017\uff1b\u5f31\u5339\u914d\u53ef\u4fee\u70bc\u4f46\u6548\u679c\u8f83\u5f31\uff1b\u4e0d\u5339\u914d\u7684\u529f\u6cd5\u6548\u7387\u6781\u4f4e\uff0c\u9ad8\u9636\u65f6\u53ef\u80fd\u65e0\u6cd5\u4fee\u70bc\u3002"
    },
    {
      "type": "patchouli:text",
      "text": "$(br)\u8f6e\u56de\u771f\u51b3\uff1a\u6697\u5c5e\u6027\uff0c\u5929\u9636\uff0c\u4fee\u70bc\u4e0a\u9650\u4e3a\u5316\u795e\u540e\u671f\u3002$(br)\u8be5\u529f\u6cd5\u4f1a\u81ea\u52a8\u83b7\u5f97\u300c\u5438\u53d6\u300d\uff0c\u53ef\u593a\u53d6\u4f4e\u4e8e\u81ea\u8eab\u4fee\u4e3a\u73a9\u5bb6\u7684\u4fee\u4e3a\u8fdb\u5ea6\u3002"
    },
    {
      "type": "patchouli:text",
      "text": "$(br)\u541e\u5929\u9b54\u529f\uff1a\u6697\u5c5e\u6027\uff0c\u5929\u9636\uff0c\u4fee\u70bc\u4e0a\u9650\u4e3a\u5316\u795e\u540e\u671f\u3002$(br)\u8be5\u529f\u6cd5\u4f1a\u81ea\u52a8\u83b7\u5f97\u300c\u541e\u5929\u300d\uff0c\u53ef\u541e\u566c\u65b9\u5757\u4e0e\u88ab\u65a9\u6740\u751f\u7075\u672c\u6e90\uff0c\u5feb\u901f\u589e\u957f\u4fee\u4e3a\u3002"
    },
    {
      "type": "patchouli:text",
      "text": "$(br)\u7834\u7a7a\u8bc0\uff1a\u98ce\u5c5e\u6027\uff0c\u5730\u9636\uff0c\u4fee\u70bc\u4e0a\u9650\u4e3a\u91d1\u4e39\u540e\u671f\u3002$(br)\u81ea\u52a8\u83b7\u5f97\u300c\u98ce\u538b\u300d\uff0c\u5f00\u542f\u540e\u62f3\u51fb\u53ef\u4ee5\u7528\u98ce\u538b\u5012\u9525\u5f62\u7834\u574f\u65b9\u5757\u3002"
    },
    {
      "type": "patchouli:text",
      "text": "$(br)\u957f\u9752\u8bc0\uff1a\u6c34/\u571f\u5c5e\u6027\uff0c\u5730\u9636\uff0c\u4fee\u70bc\u4e0a\u9650\u4e3a\u91d1\u4e39\u540e\u671f\u3002$(br)\u88ab\u52a8\u50ac\u751f\u9644\u8fd1\u690d\u7269\uff0c\u4f46\u4e0d\u4f1a\u751f\u6210\u9ad8\u8349\u3002"
    },
    {
      "type": "patchouli:text",
      "text": "$(br)\u711a\u5929\u7eed\u547d\u529f\uff1a\u706b\u5c5e\u6027\uff0c\u5730\u9636\uff0c\u4fee\u70bc\u4e0a\u9650\u4e3a\u91d1\u4e39\u540e\u671f\u3002$(br)\u9996\u6b21\u6b7b\u4ea1\u8fdb\u51651\u5206\u949f\u65c1\u89c2\u8005\u7eed\u547d\u72b6\u6001\uff0c\u62d6\u51fa\u706b\u7130\u8f68\u8ff9\uff0c\u968f\u540e\u4ee51\u9897\u5fc3\u590d\u6d3b\u3002\u56de\u6ee1\u8840\u540e\u91cd\u7f6e\u3002"
    },
    {
      "type": "patchouli:text",
      "text": "$(br)\u5bd2\u557c\u51b0\u64d2\u529f\uff1a\u51b0\u5c5e\u6027\uff0c\u5929\u9636\uff0c\u4fee\u70bc\u4e0a\u9650\u4e3a\u5316\u795e\u540e\u671f\u3002$(br)\u4e00\u8eab\u7075\u6c14\u5316\u4e3a\u6781\u5bd2\u9634\u6c14\u3002\u529f\u6cd5\u719f\u7ec3\u5ea6\u4f1a\u89e3\u9501\u4e13\u5c5e\u6cd5\u672f\uff1a\u5c0f\u6210\u89e3\u9501\u5bd2\u6676\u9501\u722a\uff0c\u5927\u6210\u89e3\u9501\u971c\u5929\u6ce3\uff0c\u5706\u6ee1\u89e3\u9501\u788e\u971c\u51cc\u9704\u3002"
    }
  ]
}
