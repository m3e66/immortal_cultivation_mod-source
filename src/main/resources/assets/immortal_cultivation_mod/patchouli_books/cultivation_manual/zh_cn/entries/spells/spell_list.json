{
  "name": "\u6cd5\u672f\u5217\u8868",
  "icon": "immortal_cultivation_mod:lingbeng_scroll",
  "category": "immortal_cultivation_mod:spells",
  "sortnum": 1,
  "pages": [
    {
      "type": "patchouli:text",
      "text": "\u706b\u7403\u672f\uff1a\u7ec3\u6c14\u524d\u671f\uff0c\u706b\u5c5e\u6027\uff0c\u6d88\u801710\u7075\u6c14\u3002$(br)\u5c04\u51fa\u706b\u7403\uff0c\u9020\u6210\u4f24\u5bb3\u5e76\u70b9\u71c3\u76ee\u6807\u3002"
    },
    {
      "type": "patchouli:text",
      "text": "$(br)\u7075\u5d29\uff1a\u7ec3\u6c14\u540e\u671f\uff0c\u96f7\u5c5e\u6027\uff0c\u6d88\u801750\u7075\u6c14\u3002$(br)\u8fdb\u5165\u5d29\u52b2\u72b6\u6001\u3002\u62f3\u51fb\u65b9\u5757\u6216\u5b9e\u4f53\u91ca\u653e\u7206\u70b8\uff0c\u91cd\u590d\u65bd\u653e\u53ef\u589e\u52a0\u534a\u5f84\u3002"
    },
    {
      "type": "patchouli:text",
      "text": "$(br)\u56de\u6625\u672f\uff1a\u7ec3\u6c14\u4e2d\u671f\uff0c\u6728\u5c5e\u6027\uff0c\u6d88\u801720\u7075\u6c14\u3002$(br)\u4ee5\u77ed\u6682\u6cbb\u7597\u6548\u679c\u6062\u590d\u751f\u547d\u3002"
    },
    {
      "type": "patchouli:text",
      "text": "$(br)\u5149\u675f\u672f\uff1a\u7ec3\u6c14\u524d\u671f\uff0c\u5149\u5c5e\u6027\uff0c\u6d88\u801730\u7075\u6c14\u3002$(br)\u8ba9\u4f60\u80fd\u591f\u611f\u77e5\u9644\u8fd1\u7684\u5b9e\u4f53\u3002"
    },
    {
      "type": "patchouli:text",
      "text": "$(br)\u9041\u5730\u672f\uff1a\u7ec3\u6c14\u540e\u671f\uff0c\u571f\u5c5e\u6027\u3002$(br)\u6f5c\u5165\u5730\u4e0b\u3001\u52a0\u901f\u79fb\u52a8\uff0c\u9732\u51fa\u5730\u9762\u524d\u6301\u7eed\u6d88\u8017\u7075\u6c14\u3002"
    },
    {
      "type": "patchouli:text",
      "text": "$(br)\u6e05\u6d01\u5492\uff1a\u7ec3\u6c14\u524d\u671f\uff0c\u6c34\u5c5e\u6027\uff0c\u6d88\u801710\u7075\u6c14\u3002$(br)\u6e05\u9664\u81ea\u8eab\u7684\u8d1f\u9762\u6548\u679c\u3002"
    },
    {
      "type": "patchouli:text",
      "text": "$(br)\u5f15\u7075\u8bc0\uff1a\u7ec3\u6c14\u524d\u671f\uff0c\u98ce\u5c5e\u6027\uff0c\u4e0d\u6d88\u8017\u7075\u6c14\u3002$(br)\u5927\u5e45\u63d0\u9ad8\u7075\u6c14\u56de\u590d\uff0c\u4f46\u4e0d\u80fd\u653b\u51fb\u6216\u9632\u5fa1\uff0c\u53d7\u5230\u4f24\u5bb3\u53d8\u4e3a3\u500d\u3002"
    },
    {
      "type": "patchouli:text",
      "text": "$(br)\u71c3\u706b\u8bc0\uff1a\u7ec3\u6c14\u524d\u671f\uff0c\u706b\u5c5e\u6027\uff0c\u6d88\u801710\u7075\u6c14\u3002$(br)\u5c04\u51fa\u76f4\u7ebf\u706b\u5149\uff0c\u547d\u4e2d\u65b9\u5757\u540e\u70b9\u71c3\u5b83\u3002"
    },
    {
      "type": "patchouli:text",
      "text": "$(br)\u7075\u89c6\uff1a\u7ec3\u6c14\u524d\u671f\uff0c\u5149\u5c5e\u6027\uff0c\u6bcf\u79d2\u6d88\u80175\u7075\u6c14\u3002$(br)\u5f00\u5173\u5f0f\u591c\u89c6\uff0c\u6548\u679c\u6fc0\u6d3b\u65f6\u6301\u7eed\u6d88\u8017\u7075\u6c14\u3002"
    },
    {
      "type": "patchouli:text",
      "text": "$(br)\u9707\u5c71\u638c\uff1a\u7b51\u57fa\u4e2d\u671f\uff0c\u571f\u5c5e\u6027\uff0c\u5730\u9636\uff0c\u6d88\u8017130\u7075\u6c14\u3002$(br)\u91ca\u653e\u5de8\u5927\u638c\u5f62\u571f\u884c\u7c92\u5b50\u6ce2\uff0c\u6301\u7eed3\u79d2\u3002\u638c\u5370\u89e6\u78b0\u7684\u65b9\u5757\u4f1a\u88ab\u9707\u788e\u3002"
    },
    {
      "type": "patchouli:text",
      "text": "$(br)\u5149\u7403\u672f\uff1a\u7b51\u57fa\u540e\u671f\uff0c\u5149\u5c5e\u6027\uff0c\u53ec\u5524\u6d88\u801730\u7075\u6c14\uff0c\u53d1\u5c04\u6bcf\u679a\u6d88\u801710\u7075\u6c14\u3002$(br)\u5728\u8eab\u540e\u53ec\u55246\u679a\u516d\u8fb9\u5f62\u5149\u7403\uff0c\u6700\u591a\u53e0\u52a03\u5c42\u3002\u62f3\u51fb\u53d1\u5c041\u679a\uff0c\u6f5c\u884c\u62f3\u51fb\u53d1\u5c04\u5168\u90e8\u3002\u6bcf\u679a\u9020\u621050\u70b9\u4f24\u5bb3\u5e76\u6700\u591a\u7834\u574f24\u4e2a\u65b9\u5757\u3002"
    }
  ]
}
