{
  "name": "\u6cd5\u672f\u5217\u8868",
  "icon": "immortal_cultivation_mod:lingbeng_scroll",
  "category": "immortal_cultivation_mod:spells",
  "sortnum": 1,
  "pages": [
    {
      "type": "patchouli:text",
      "text": "\u706b\u7403\u672f\uff1a\u7ec3\u6c14\u524d\u671f\uff0c\u706b\u5c5e\u6027\uff0c\u6d88\u801710\u7075\u6c14\u3002$(br)\u56de\u6625\u672f\uff1a\u7ec3\u6c14\u4e2d\u671f\uff0c\u6728\u5c5e\u6027\u3002$(br)\u7075\u5d29\uff1a\u7ec3\u6c14\u540e\u671f\uff0c\u96f7\u5c5e\u6027\uff0c\u6d88\u801750\u7075\u6c14\u3002$(br)\u5149\u675f\u672f\uff1a\u6d88\u801730\u7075\u6c14\uff0c\u53ea\u6709\u65bd\u6cd5\u8005\u53ef\u89c1\u3002"
    },
    {
      "type": "patchouli:text",
      "text": "\u9041\u5730\u672f\uff1a\u7ec3\u6c14\u540e\u671f\u3002\u6f5c\u5165\u5730\u4e0b\u3001\u52a0\u901f\u79fb\u52a8\uff0c\u9732\u51fa\u5730\u9762\u524d\u6301\u7eed\u6d88\u8017\u7075\u6c14\u3002$(br)\u6e05\u6d01\u5492\uff1a\u7ec3\u6c14\u524d\u671f\uff0c\u6c34\u5c5e\u6027\uff0c\u6e05\u9664\u8d1f\u9762\u6548\u679c\u3002$(br)\u7075\u89c6\uff1a\u5f00\u5173\u5f0f\u591c\u89c6\uff0c\u6bcf\u79d2\u6d88\u80175\u7075\u6c14\u3002"
    },
    {
      "type": "patchouli:text",
      "text": "\u5f15\u7075\u8bc0\uff1a\u7ec3\u6c14\u524d\u671f\u3002\u4e0d\u6d88\u8017\u7075\u6c14\uff0c\u5927\u5e45\u63d0\u9ad8\u7075\u6c14\u56de\u590d\uff0c\u4f46\u4e0d\u80fd\u653b\u51fb\u6216\u9632\u5fa1\uff0c\u53d7\u5230\u4f24\u5bb3\u53d8\u4e3a3\u500d\u3002$(br)\u71c3\u706b\u8bc0\uff1a\u7ec3\u6c14\u524d\u671f\uff0c\u706b\u5c5e\u6027\uff0c\u547d\u4e2d\u65b9\u5757\u540e\u70b9\u71c3\u5b83\u3002"
    }
  ]
}
