{
  "name": "\u7075\u6839",
  "icon": "minecraft:amethyst_shard",
  "category": "immortal_cultivation_mod:cultivation",
  "sortnum": 1,
  "pages": [
    {
      "type": "patchouli:text",
      "text": "\u7075\u6839\u662f\u968f\u673a\u751f\u6210\u7684\uff0c\u53ef\u80fd\u62e5\u6709\u4e00\u79cd\u6216\u591a\u79cd\u5c5e\u6027\u3002$(br2)\u4e94\u884c\u7075\u6839\uff1a\u91d1\u3001\u6728\u3001\u6c34\u3001\u706b\u3001\u571f\u3002$(br)\u53d8\u5f02\u7075\u6839\uff1a\u96f7\u3001\u51b0\u3001\u98ce\u3001\u5149\u3001\u6697\u3002$(br)\u65e0\u7075\u6839\u6216\u4f2a\u7075\u6839\u4fee\u70bc\u6781\u6162\u3002"
    },
    {
      "type": "patchouli:text",
      "text": "$(br)\u7075\u6839\u6570\u91cf\u4f1a\u5f71\u54cd\u4fee\u70bc\u901f\u5ea6\u3002$(br)\u5355\u7075\u6839\uff1a\u6700\u5feb\u3002$(br)\u53cc\u7075\u6839\uff1a\u8f83\u5feb\u3002$(br)\u4e09\u6216\u56db\u7075\u6839\uff1a\u8f83\u6162\u3002$(br)\u4e94\u7075\u6839\uff1a\u6700\u6162\uff0c\u4f46\u517c\u5bb9\u6027\u6700\u5f3a\u3002"
    },
    {
      "type": "patchouli:text",
      "text": "$(br)\u7075\u6839\u54c1\u7ea7\u4ece\u9ad8\u5230\u4f4e\u4e3a\uff1a\u5929\u3001\u5730\u3001\u7384\u3001\u9ec4\u3002$(br2)\u4f7f\u7528\u548c\u81ea\u8eab\u7075\u6839\u5c5e\u6027\u76f8\u540c\u7684\u6cd5\u672f\u65f6\uff0c\u4f1a\u83b7\u5f972\u500d\u4f24\u5bb3\u62162\u500d\u6301\u7eed\u65f6\u95f4\u3002"
    }
  ]
}
