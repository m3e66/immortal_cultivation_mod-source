  "item.immortal_cultivation_mod.kongshi_shu_scroll": "控尸术玉简",
  "spell.immortal_cultivation_mod.kongshi_shu": "控尸术",
  "spell.immortal_cultivation_mod.kongshi_shu.damage": "驯服僵尸或遗身",
  "spell.immortal_cultivation_mod.kongshi_shu.qi_cost": "30灵气",
  "spell.immortal_cultivation_mod.kongshi_shu.cooldown": "指向",
  "spell.immortal_cultivation_mod.fireball.description": "将灵气凝于掌心化为炽热火球，掷出后焚敌灼物。",
  "spell.immortal_cultivation_mod.lingbeng.description": "运转灵力进入崩裂之态，再次催动可延长法效并扩大爆炎范围，最多叠至十重。",
  "spell.immortal_cultivation_mod.regeneration.description": "引灵气滋养肉身，短时间内持续恢复伤势。",
  "spell.immortal_cultivation_mod.beam.description": "凝聚灵力化作独有光痕，仅施术者可见，片刻后散去。",
  "spell.immortal_cultivation_mod.earth_escape.description": "遁入土石之间高速穿行，在地下持续消耗灵气，回到地面后解除。",
  "spell.immortal_cultivation_mod.cleanse.description": "诵动清洁咒洗涤周身，驱散负面状态。",
  "spell.immortal_cultivation_mod.qi_gathering.description": "专心吸纳天地灵气，期间失去攻防能力，受到伤害会加重。",
  "spell.immortal_cultivation_mod.lingzhi_bullet.description": "指尖凝出细小灵力弹，消耗极低，可伤敌并击碎少量方块。",
  "spell.immortal_cultivation_mod.wind_blade.description": "聚风成刃，斩击刺切皆可重创敌手。",
  "spell.immortal_cultivation_mod.wind_step.description": "随心开启的身法，足下缠绕清风，提高速度并可空中再跃一次。",
  "spell.immortal_cultivation_mod.yufeng_jue.description": "御风低空飞行，每秒消耗灵气。",
  "spell.immortal_cultivation_mod.smoke_art.description": "凝雾成弹，落点烟雾扩散，使目标短时间失明。",
  "spell.immortal_cultivation_mod.huti_qi.description": "真气覆身形成薄气膜，抵挡凡兵碎石，扛不住修士术法。",
  "spell.immortal_cultivation_mod.michen_zhang.description": "扬起尘土遮蔽视野，干扰对手远程瞄准，无法减免伤害。",
  "spell.immortal_cultivation_mod.sliding_water.description": "发出水弹，落地形成浅水陷阱，踏入者行动错乱。",
  "spell.immortal_cultivation_mod.ignite_flare.description": "引真火化作火线直掠而去，触及草木土石会燃起明火。",
  "spell.immortal_cultivation_mod.spirit_sight.description": "自由开关的灵目之术，开启后黑夜如昼，每秒消耗灵气。",
  "spell.immortal_cultivation_mod.light_beam_attack.description": "消耗灵气在身后召出六枚六边形灵光球，拳击发射，威力极强。",
  "spell.immortal_cultivation_mod.dielang_shield.description": "以水行灵力凝成层层护盾，层数越多消耗越高，承伤越强。",
  "spell.immortal_cultivation_mod.zhenshan_palm.description": "引大地厚土之力凝为巨掌，掌势持续数息，所过之处土石崩碎。",
  "spell.immortal_cultivation_mod.weiya.description": "随心开启的气场秘术，周身散出修为威压，每秒消耗1%最大灵气，压制修为不及自身的生灵。",
  "spell.immortal_cultivation_mod.zibao.description": "耗尽所有寿元，以自身为中心自爆。范围：金丹50格，元婴80格，化神100格，炼虚200格，合体300格，大乘400格，渡劫500格。",
  "spell.immortal_cultivation_mod.absorb_cultivation.description": "发射暗属性灵弹，命中低修为目标后抽取其一成修为进度归为己用。",
  "spell.immortal_cultivation_mod.tuntian.description": "吞噬周围土石并伤害生灵，将方块与被斩杀目标的本源化为修为。",
  "spell.immortal_cultivation_mod.fengya.description": "开启后每次挥拳都会掀起风锥，伤敌破石；达到金丹后潜行挥拳可唤出更大风锥。",
  "spell.immortal_cultivation_mod.dingshen.description": "默诵玄咒，凝金行灵弹击向目标，使低修为者身体僵硬无法行动。",
  "spell.immortal_cultivation_mod.yinlei_jue.description": "沟通天地灵机，凝雷符飞射，引九天雷光坠落轰杀目标。",
  "spell.immortal_cultivation_mod.wulei_zhengfa.description": "道门正统雷法，掌心雷与天雷齐落，五道雷柱纵横，专克邪祟。",
  "spell.immortal_cultivation_mod.liuguang_jianying.description": "放出五十道流光剑球，满蓄力最高八十道，向四面八方飞射。每道剑球命中方块、命中敌人、飞行十格或到达施法者十格半径时会改向；半径改向会选择不再向外飞的其他方向，而不是总是直奔施法者。第二十次改向后直接消失。",
  "spell.immortal_cultivation_mod.sifang_jie.description": "小型防护结界，可护住三五人，隔绝毒物与低级幻术。",
  "spell.immortal_cultivation_mod.gushi_shield.description": "土系真元凝成厚重石盾，耐劈砍钝击，可抵御常规五行术。",
  "spell.immortal_cultivation_mod.kongshi_shu.description": "驱使僵尸或遗身。低于自身境界，或最多高出一个大境界的目标可被控制。",
  "method_special.immortal_cultivation_mod.blood_demon": "修炼此功法可炼自身精血，凝出血气之力，此后术法与修炼皆可以血气替代灵气。",
  "method_special.immortal_cultivation_mod.reincarnation_true_art": "修成后自然习得吸取之术，命中修为低于自身者可夺其修为。",
  "method_special.immortal_cultivation_mod.tuntian_demon_art": "修成吞天神通，可吞噬土石万物与生灵本源，化为自身修为。",
  "method_special.immortal_cultivation_mod.pokong_jue": "修成后习得风压，挥拳可撕裂空气，伤敌破石。",
  "method_special.immortal_cultivation_mod.changqing_jue": "灵气潜移默化滋养周围草木，但不会滋生杂草。",
  "method_special.immortal_cultivation_mod.fentian_life_renewal": "初次死亡时化作灵体暂存，之后凝魂复生。完全恢复后可再次触发。",
  "item.immortal_cultivation_mod.hanti_bingqin_method": "寒啼冰擒功",
  "method.immortal_cultivation_mod.hanti_bingqin": "寒啼冰擒功",
